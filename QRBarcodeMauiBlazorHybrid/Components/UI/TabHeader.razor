<div class="tab-header fixed top-0 z-50 grid w-screen justify-center bg-primary p-3 text-text">
    <h1 class="text-4xl font-bold">@Name</h1>
    @if (HandleInput.HasDelegate)
    {
        <input class="form-input mt-4"
               placeholder=@InputPlaceholder
               @oninput=HandleInput />
    }
</div>

@code {
    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? InputPlaceholder { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs> HandleInput { get; set; }
}
