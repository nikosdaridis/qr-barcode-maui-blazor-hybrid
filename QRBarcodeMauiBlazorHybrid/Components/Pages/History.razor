@page "/history"

@inherits CodesBase

@{
    base.BuildRenderTree(__builder);
}

@code {
    /// <summary>
    /// Loads all codes and set active tab.
    /// </summary>
    protected override async Task LoadComponentDataAsync(LocalStorageService localStorageService)
    {
        tabName = RoutePaths.HISTORY_LABEL;
        await localStorageService.SaveActiveTabAsync(RoutePaths.HISTORY);
        codes = await localStorageService.GetCodesAsync();
    }
}
