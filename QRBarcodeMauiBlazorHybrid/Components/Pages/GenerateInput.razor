@inherits PageBase

@page "/generate/{Type}/{Format}"

@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject LocalStorageService LocalStorageService

<TabHeader Name=@($"Generate {Format}") />

<div class="main-content w-content grid">
    @if (_model is not null)
    {
        <EditForm Model=@_model OnValidSubmit=HandleSubmitAsync>
            <DataAnnotationsValidator />
            <ValidationSummary />
            @foreach (PropertyInfo property in _model.GetType().GetProperties().Where(IsRenderableProperty))
            {
                <label class="my-2 block" for=@property.Name>@property.Name</label>

                Type underlyingType = Nullable.GetUnderlyingType(property.PropertyType) ?? property.PropertyType;
                string[]? dropdownOptions = property.GetCustomAttribute<DropdownOptionsAttribute>()?.Options;

                if (underlyingType.IsEnum)
                {
                    object? selectedEnum = property.GetValue(_model);
                    <select class="form-input"
                            value=@selectedEnum?.ToString()
                            @onchange=@((ChangeEventArgs e) => SetValue(property, e.Value))>
                        @foreach (object enumValue in Enum.GetValues(underlyingType))
                        {
                            string memberName = enumValue.ToString()!;
                            <option value=@memberName>@GetEnumDisplayName(underlyingType, memberName)</option>
                        }
                    </select>
                }
                else if (dropdownOptions is not null)
                {
                    <select class="form-input"
                            @onchange=@((ChangeEventArgs e) => SetValue(property, e.Value))>
                        @foreach (string option in dropdownOptions)
                        {
                            <option value=@option>@option</option>
                        }
                    </select>
                }
                else
                {
                    string? inputType = property.GetCustomAttribute<InputTypeAttribute>()?.Type;
                    object? propertyValue = property.GetValue(_model);

                    if (property.PropertyType == typeof(DateTime) && propertyValue is not null)
                    {
                        propertyValue = ((DateTime)propertyValue).ToString("yyyy-MM-ddTHH:mm");
                    }

                    <input class="form-input"
                           type=@inputType
                           value=@propertyValue
                           step=@(property.PropertyType == typeof(double) || Nullable.GetUnderlyingType(property.PropertyType) == typeof(double) ? "0.000001" : "1")
                           @onchange=@((ChangeEventArgs e) => SetValue(property, e.Value)) />
                }
            }
            <button class="mt-4 rounded-xl bg-primary p-3 text-2xl" type="submit" @ref=_generateButton
                    @onclick=@(async () => await JSRuntime.InvokeVoidAsync("playButtonAnimation", _generateButton))>
                Generate
            </button>
        </EditForm>
    }
</div>

<TabBar />

@code {
    [Parameter]
    public string? Type { get; set; }

    [Parameter]
    public string? Format { get; set; }

    private IGenerateModel? _model;
    private ElementReference _generateButton;

    /// <summary>
    /// Initializes code generate model based on type and format.
    /// </summary>
    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (string.IsNullOrWhiteSpace(Type) || string.IsNullOrWhiteSpace(Format))
        {
            return;
        }

        _model = BarcodeFormats.Get(Format)?.Factory()
            ?? QrFormats.Get(Type)?.Factory()
            ?? new TextModel();
    }

    /// <summary>
    /// Sets value of property, parsing enums via member name and other types via <see cref="Convert.ChangeType(object?, System.Type)"/>.
    /// </summary>
    private void SetValue(PropertyInfo property, object? value)
    {
        string? valueString = value?.ToString();

        if (string.IsNullOrWhiteSpace(valueString))
        {
            if (IsNullablePropertyType(property.PropertyType))
            {
                property.SetValue(_model, null);
            }
            return;
        }

        Type underlyingType = Nullable.GetUnderlyingType(property.PropertyType) ?? property.PropertyType;

        try
        {
            object? converted = underlyingType.IsEnum
                ? Enum.Parse(underlyingType, valueString)
                : Convert.ChangeType(value, underlyingType);
            property.SetValue(_model, converted);
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"{nameof(SetValue)} conversion failed for {property.Name}: {ex}");
        }
    }

    /// <summary>
    /// Returns true when the property accepts <c>null</c> — reference types or <see cref="Nullable{T}"/>.
    /// </summary>
    private static bool IsNullablePropertyType(Type type) =>
        !type.IsValueType || Nullable.GetUnderlyingType(type) is not null;

    /// <summary>
    /// Saves generated code and navigates to details tab.
    /// </summary>
    private async Task HandleSubmitAsync()
    {
        if (_model is null)
        {
            return;
        }

        if (_model is Ean13Model { IsIsbn: true })
        {
            Type = QrFormats.ISBN_TYPE;
        }

        string id = await LocalStorageService.SaveCodeAsync(_model.GetValue(), Type!, Format!, CodeSource.GENERATED);

        NavigationManager.NavigateTo($"/details/{id}");
    }

    /// <summary>
    /// Filters reflected properties to those that produce a form input. Skips computed/derived properties.
    /// </summary>
    private static bool IsRenderableProperty(PropertyInfo property) =>
        property.CanWrite;

    /// <summary>
    /// Resolves an enum member's display label, preferring <see cref="DisplayAttribute.Name"/> when provided.
    /// </summary>
    private static string GetEnumDisplayName(Type enumType, string memberName) =>
        enumType.GetField(memberName)?.GetCustomAttribute<DisplayAttribute>()?.Name ?? memberName;
}
